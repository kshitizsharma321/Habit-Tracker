# Server port (Render sets this automatically in production)
PORT=5000

# MongoDB connection string
# Local:
MONGODB_URI=mongodb://localhost:27017/habit-tracker
# Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/habit-tracker?retryWrites=true&w=majority

# Frontend URL for CORS (set to your Vercel URL in production, leave empty for local dev)
FRONTEND_URL=
